@model List<CampaignManagement.Models.Entity.mstInfluencer>
@{
    ViewData["Title"] = "Influencers Stats";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">Influencers Stats</h1>
    </div>
    <button class="btn btn-danger px-4 py-2" data-bs-toggle="modal" data-bs-target="#addInfluencerModal">
        <i class="fa-solid fa-plus me-2"></i> Add Profile
    </button>
</div>

<!-- Search & Sort -->
<div class="custom-card py-3 px-4 mb-4">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Search by name, category, or location...">
            </div>
        </div>
        <div class="col-md-3 ms-auto">
            <select class="form-select bg-white" onchange="this.form.submit()">
                <option>Sort by</option>
                <option>Engagement Rate</option>
                <option>Followers</option>
            </select>
        </div>
    </form>
</div>

<!-- Influencers Grid -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">No influencer profiles registered</div>
    }
    else
    {
        @foreach (var inf in Model)
        {
            <div class="col">
                <div class="custom-card h-100 p-4 border rounded-3 position-relative">
                    <!-- Rating Star in top right -->
                    <span class="position-absolute top-0 end-0 m-3 text-warning">
                        @for (int i = 0; i < (inf.reliabilityScore > 0 ? inf.reliabilityScore : 4); i++)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                    </span>

                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="profile-avatar bg-light p-1 border">
                            <img src="https://api.dicebear.com/7.x/pixel-art/svg?seed=@(inf.name)" alt="@inf.name" />
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">@inf.name</h6>
                            <span class="text-muted fs-8">@(inf.niche ?? "Food Exploration and Travel content creator")</span>
                        </div>
                    </div>

                    <!-- Platform icons -->
                    <div class="mb-3 fs-7 text-muted">
                        Social Media Platforms:
                        <span class="text-danger ms-2">
                            <i class="fa-brands fa-youtube me-1"></i>
                            <i class="fa-brands fa-instagram"></i>
                        </span>
                    </div>

                    <!-- Stats Row -->
                    <div class="row text-center border-top border-bottom py-2 my-3 g-0">
                        <div class="col-3 border-end">
                            <span class="text-muted fs-9 d-block">Followers</span>
                            <span class="fw-bold text-dark fs-8">@inf.followers</span>
                        </div>
                        <div class="col-3 border-end">
                            <span class="text-muted fs-9 d-block">Engagement</span>
                            <span class="fw-bold text-dark fs-8">@inf.engagement%</span>
                        </div>
                        <div class="col-3 border-end">
                            <span class="text-muted fs-9 d-block">Avg. Views</span>
                            <span class="fw-bold text-dark fs-8">@inf.avgViews</span>
                        </div>
                        <div class="col-3">
                            <span class="text-muted fs-9 d-block">Est. Conversion</span>
                            <span class="fw-bold text-dark fs-8">@inf.estConversion%</span>
                        </div>
                    </div>

                    <!-- Cost & Actions -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <span class="text-muted fs-9 d-block">Est Cost</span>
                            <span class="fw-bold text-dark fs-7">₹ @inf.estCostMin.ToString("N0") - ₹ @inf.estCostMax.ToString("N0")</span>
                        </div>
                        <a href="@Url.Action("Profile", new { id = inf.mstInfluencerId })" class="btn btn-outline-primary btn-sm rounded-pill px-3">View Profile</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Add Influencer Modal -->
<div class="modal fade" id="addInfluencerModal" tabindex="-1" aria-labelledby="addInfluencerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="addInfluencerModalLabel">Add Influencer Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="SaveInfluencer">
                <div class="modal-body p-4">
                    <!-- Basic Info Section -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-user me-2"></i>Basic Information</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="inf_name" class="form-label fw-medium">Influencer Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="inf_name" name="name" required placeholder="e.g. Irfan's View">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_phoneNumber" class="form-label fw-medium">Phone Number</label>
                            <input type="tel" class="form-control" id="inf_phoneNumber" name="phoneNumber" placeholder="e.g. +91 98420 12345">
                        </div>
                        <div class="col-md-4">
                            <label for="inf_category" class="form-label fw-medium">Category</label>
                            <input type="text" class="form-control" id="inf_category" name="category" placeholder="e.g. Food, Travel">
                        </div>
                        <div class="col-md-4">
                            <label for="inf_niche" class="form-label fw-medium">Niche</label>
                            <input type="text" class="form-control" id="inf_niche" name="niche" placeholder="e.g. Street Food, Baking">
                        </div>
                        <div class="col-md-4">
                            <label for="inf_location" class="form-label fw-medium">Location</label>
                            <input type="text" class="form-control" id="inf_location" name="location" placeholder="e.g. Chennai">
                        </div>
                        <div class="col-md-4">
                            <label for="inf_dateOfBirth" class="form-label fw-medium">Date of Birth</label>
                            <input type="date" class="form-control" id="inf_dateOfBirth" name="dateOfBirth">
                        </div>
                        <div class="col-md-4">
                            <label for="inf_gender" class="form-label fw-medium">Gender</label>
                            <select class="form-select" id="inf_gender" name="gender">
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="inf_dateOfOnboarding" class="form-label fw-medium">Date of Onboarding</label>
                            <input type="date" class="form-control" id="inf_dateOfOnboarding" name="dateOfOnboarding">
                        </div>
                        <div class="col-12">
                            <label for="inf_shortDescription" class="form-label fw-medium">Short Description</label>
                            <textarea class="form-control" id="inf_shortDescription" name="shortDescription" rows="2" placeholder="e.g. Food exploration and travel content creator based in Chennai"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_languagesFamiliar" class="form-label fw-medium">Languages Familiar</label>
                            <input type="text" class="form-control" id="inf_languagesFamiliar" name="languagesFamiliar" placeholder="e.g. Tamil, English, Hindi">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_influencerInterests" class="form-label fw-medium">Influencer Interests</label>
                            <input type="text" class="form-control" id="inf_influencerInterests" name="influencerInterests" placeholder="e.g. Street Food, Vlogging, Hotels">
                        </div>
                        <div class="col-12">
                            <label for="inf_residentialAddress" class="form-label fw-medium">Residential Address</label>
                            <textarea class="form-control" id="inf_residentialAddress" name="residentialAddress" rows="2" placeholder="Full residential address"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_profilePicturePath" class="form-label fw-medium">Profile Picture URL/Path</label>
                            <input type="text" class="form-control" id="inf_profilePicturePath" name="profilePicturePath" placeholder="e.g. /uploads/irfan.jpg">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_instagramUrl" class="form-label fw-medium">Instagram URL</label>
                            <input type="url" class="form-control" id="inf_instagramUrl" name="instagramUrl" placeholder="e.g. https://instagram.com/irfansview">
                        </div>
                    </div>
                    
                    <!-- Creator ID Auto-Generated Notice -->
                    <div class="alert alert-info d-flex align-items-center gap-2 mb-4 fs-8">
                        <i class="fa-solid fa-circle-info"></i>
                        <span><strong>Creator ID</strong> will be auto-generated based on the social media platform (e.g. CHYT03, CHIG04).</span>
                    </div>

                    <!-- Social & Manager Info -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-share-nodes me-2"></i>Social & Manager Info</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="inf_socialMediaPlatforms" class="form-label fw-medium">Social Media Platforms</label>
                            <input type="text" class="form-control" id="inf_socialMediaPlatforms" name="socialMediaPlatforms" placeholder="e.g. YouTube, Instagram">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_instagramProfile" class="form-label fw-medium">Instagram Handle</label>
                            <input type="text" class="form-control" id="inf_instagramProfile" name="instagramProfile" placeholder="e.g. @@irfansview">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_managerName" class="form-label fw-medium">Manager Name</label>
                            <input type="text" class="form-control" id="inf_managerName" name="managerName" placeholder="e.g. Sohail">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_managerNumber" class="form-label fw-medium">Manager Mobile</label>
                            <input type="text" class="form-control" id="inf_managerNumber" name="managerNumber" placeholder="9842158724">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_whatsAppContact" class="form-label fw-medium">WhatsApp Contact</label>
                            <input type="text" class="form-control" id="inf_whatsAppContact" name="whatsAppContact" placeholder="9842158724">
                        </div>
                    </div>

                    <!-- Stats Section -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-chart-bar me-2"></i>Performance Stats</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="inf_followers" class="form-label fw-medium">Followers Count</label>
                            <input type="text" class="form-control" id="inf_followers" name="followers" placeholder="e.g. 245K">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_engagement" class="form-label fw-medium">Engagement Rate (%)</label>
                            <input type="number" step="0.01" class="form-control" id="inf_engagement" name="engagement" placeholder="7.2">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_avgViews" class="form-label fw-medium">Avg. Views</label>
                            <input type="text" class="form-control" id="inf_avgViews" name="avgViews" placeholder="e.g. 180K">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_estConversion" class="form-label fw-medium">Est. Conversion Rate (%)</label>
                            <input type="number" class="form-control" id="inf_estConversion" name="estConversion" placeholder="3">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_estCostMin" class="form-label fw-medium">Min Est. Cost (₹)</label>
                            <input type="number" class="form-control" id="inf_estCostMin" name="estCostMin" placeholder="2,500">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_estCostMax" class="form-label fw-medium">Max Est. Cost (₹)</label>
                            <input type="number" class="form-control" id="inf_estCostMax" name="estCostMax" placeholder="4,000">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_reliabilityScore" class="form-label fw-medium">Reliability Rating (1-5)</label>
                            <input type="number" min="1" max="5" class="form-control" id="inf_reliabilityScore" name="reliabilityScore" placeholder="4">
                        </div>
                    </div>
                    
                    <!-- Payment Info -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-credit-card me-2"></i>Payment Information</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="inf_paymentDetails" class="form-label fw-medium">Payment Details</label>
                            <textarea class="form-control" id="inf_paymentDetails" name="paymentDetails" rows="2" placeholder="e.g. UPI: irfan@paytm | Bank: HDFC A/C No: XXXX1234"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Save Profile</button>
                </div>
            </form>
        </div>
    </div>
</div>
