@model List<CampaignManagement.Models.Entity.mstInfluencer>
@{
    ViewData["Title"] = "Influencer Inventory & Stats";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">Influencer Inventory</h1>
        <p class="text-muted fs-7 mb-0">Collaborator directory & profile management for Wander With Food</p>
    </div>
    <button class="btn btn-danger px-4 py-2 rounded-pill shadow-sm fw-medium" data-bs-toggle="modal" data-bs-target="#addInfluencerModal">
        <i class="fa-solid fa-plus me-2"></i> Add Profile
    </button>
</div>

<!-- Search & Filter Bar -->
<div class="custom-card py-3 px-4 mb-4 border-0 shadow-sm">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Search by name, niche, location, or creator ID...">
            </div>
        </div>
        <div class="col-md-4 ms-auto">
            <select class="form-select bg-white" onchange="this.form.submit()">
                <option value="">Sort by Reliability & Engagement</option>
                <option value="Followers">Followers Count</option>
                <option value="Conversion">Est. Conversion Rate</option>
            </select>
        </div>
    </form>
</div>

<!-- Influencer Inventory Grid -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="fa-solid fa-users-slash fs-1 text-secondary mb-3 d-block"></i>
            No influencer profiles registered in inventory. Click "Add Profile" to onboard new creators.
        </div>
    }
    else
    {
        @foreach (var inf in Model)
        {
            var profilePic = !string.IsNullOrEmpty(inf.profilePicturePath) 
                ? inf.profilePicturePath 
                : $"https://api.dicebear.com/7.x/pixel-art/svg?seed={inf.name}";

            <div class="col">
                <div class="custom-card h-100 p-4 border-0 shadow-sm rounded-4 position-relative card-hover" 
                     style="cursor: pointer; transition: all 0.25s ease-in-out;"
                     onclick="window.location.href='@Url.Action("Profile", new { id = inf.mstInfluencerId })'">
                    
                    <!-- Rating Star in top right -->
                    <span class="position-absolute top-0 end-0 m-3 text-warning">
                        @for (int i = 0; i < (inf.reliabilityScore > 0 ? inf.reliabilityScore : 4); i++)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                    </span>

                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="profile-avatar bg-light p-1 border rounded-circle shadow-sm overflow-hidden" style="width: 54px; height: 54px; min-width: 54px;">
                            <img src="@profilePic" alt="@inf.name" class="w-100 h-100 object-fit-cover rounded-circle" />
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0 text-dark">@inf.name</h6>
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-0 fs-9 mb-1">
                                @(string.IsNullOrEmpty(inf.creatorId) ? "CHIG" + inf.mstInfluencerId.ToString("D2") : inf.creatorId)
                            </span>
                            <div class="text-muted fs-8">@(inf.niche ?? inf.category ?? "Food Exploration & Lifestyle")</div>
                        </div>
                    </div>

                    <!-- Short Description -->
                    <p class="text-muted fs-8 mb-3 text-truncate-2" style="min-height: 38px;">
                        @(inf.shortDescription ?? "Food exploration and travel content creator collaborating with Wander With Food.")
                    </p>

                    <!-- Custom Interests / Tags -->
                    @if (!string.IsNullOrEmpty(inf.influencerInterests))
                    {
                        <div class="d-flex flex-wrap gap-1 mb-3">
                            @foreach (var tag in inf.influencerInterests.Split(',', StringSplitOptions.TrimEntries).Take(3))
                            {
                                <span class="badge bg-light text-muted border fs-9 rounded-pill">#@tag</span>
                            }
                        </div>
                    }

                    <!-- Stats Row -->
                    <div class="row text-center border-top border-bottom py-2 my-3 g-0 bg-light rounded-3">
                        <div class="col-4 border-end">
                            <span class="text-muted fs-9 d-block">Followers</span>
                            <span class="fw-bold text-dark fs-8">@(string.IsNullOrEmpty(inf.followers) ? "245K" : inf.followers)</span>
                        </div>
                        <div class="col-4 border-end">
                            <span class="text-muted fs-9 d-block">Location</span>
                            <span class="fw-bold text-dark fs-8 text-truncate d-block px-1">@(inf.location ?? "Chennai")</span>
                        </div>
                        <div class="col-4">
                            <span class="text-muted fs-9 d-block">Onboarded</span>
                            <span class="fw-bold text-dark fs-8">@(inf.dateOfOnboarding?.ToString("MMM yyyy") ?? "Jan 2026")</span>
                        </div>
                    </div>

                    <!-- Action Footer -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-primary fs-8 fw-medium">
                            <i class="fa-brands fa-instagram me-1"></i> @(string.IsNullOrEmpty(inf.instagramProfile) ? "@" + inf.name.Replace(" ", "").ToLower() : inf.instagramProfile)
                        </span>
                        <a href="@Url.Action("Profile", new { id = inf.mstInfluencerId })" class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm" onclick="event.stopPropagation();">
                            View Profile <i class="fa-solid fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Add Influencer Modal (Top Right Form) collecting all 17 fields -->
<div class="modal fade" id="addInfluencerModal" tabindex="-1" aria-labelledby="addInfluencerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold" id="addInfluencerModalLabel">Add Influencer Profile</h5>
                    <p class="text-muted fs-8 mb-0">Register a new creator in Wander With Food inventory</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="SaveInfluencer">
                <div class="modal-body p-4">
                    
                    <!-- 1. Basic Info Section -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-user me-2"></i>1. Basic Profile Details</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="inf_name" class="form-label fw-medium">1. Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="inf_name" name="name" required placeholder="e.g. Irfan's View">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_phoneNumber" class="form-label fw-medium">2. Phone Number</label>
                            <input type="tel" class="form-control" id="inf_phoneNumber" name="phoneNumber" placeholder="e.g. +91 98420 12345">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_followers" class="form-label fw-medium">3. Followers in Instagram</label>
                            <input type="text" class="form-control" id="inf_followers" name="followers" placeholder="e.g. 245K / 1.2M">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_niche" class="form-label fw-medium">4. Niche</label>
                            <input type="text" class="form-control" id="inf_niche" name="niche" placeholder="e.g. Street Food, Restaurant Reviews">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_gender" class="form-label fw-medium">5. Gender</label>
                            <select class="form-select" id="inf_gender" name="gender">
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_location" class="form-label fw-medium">6. Location</label>
                            <input type="text" class="form-control" id="inf_location" name="location" placeholder="e.g. Chennai">
                        </div>
                    </div>

                    <!-- 2. Additional Profile Attributes -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-address-card me-2"></i>2. Extended Profile Information</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label for="inf_shortDescription" class="form-label fw-medium">8. Short Description</label>
                            <textarea class="form-control" id="inf_shortDescription" name="shortDescription" rows="2" placeholder="Brief bio or description of the creator..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_languagesFamiliar" class="form-label fw-medium">9. Languages Familiar</label>
                            <input type="text" class="form-control" id="inf_languagesFamiliar" name="languagesFamiliar" placeholder="e.g. Tamil, English, Telugu">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_influencerInterests" class="form-label fw-medium">17. Influencer Interest (Custom Tags)</label>
                            <input type="text" class="form-control" id="inf_influencerInterests" name="influencerInterests" placeholder="e.g. Food Vlogging, Travel, Biryani Exploration">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_profilePicturePath" class="form-label fw-medium">10. Profile Picture URL / Path</label>
                            <input type="text" class="form-control" id="inf_profilePicturePath" name="profilePicturePath" placeholder="e.g. /uploads/irfan.jpg or image URL">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_instagramUrl" class="form-label fw-medium">11. Instagram URL</label>
                            <input type="url" class="form-control" id="inf_instagramUrl" name="instagramUrl" placeholder="e.g. https://instagram.com/irfansview">
                        </div>
                        <div class="col-12">
                            <label for="inf_residentialAddress" class="form-label fw-medium">12. Residential Address</label>
                            <textarea class="form-control" id="inf_residentialAddress" name="residentialAddress" rows="2" placeholder="Complete residential/office address"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_dateOfOnboarding" class="form-label fw-medium">13. Date of Onboarding</label>
                            <input type="date" class="form-control" id="inf_dateOfOnboarding" name="dateOfOnboarding">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_dateOfBirth" class="form-label fw-medium">14. DOB (Date of Birth)</label>
                            <input type="date" class="form-control" id="inf_dateOfBirth" name="dateOfBirth">
                        </div>
                    </div>

                    <!-- 3. Creator ID & Manager Info -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-id-badge me-2"></i>3. System & Manager Info</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <!-- 15. Creator ID Auto-Generated Notice -->
                            <div class="alert alert-info border-info-subtle d-flex align-items-center gap-2 mb-0 fs-8">
                                <i class="fa-solid fa-wand-magic-sparkles text-info fs-5"></i>
                                <div>
                                    <strong>15. Creator ID (Auto Generated):</strong> A unique Creator ID (e.g. <code>CHIG01</code> or <code>CHYT02</code>) will be automatically generated upon saving.
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label for="inf_managerName" class="form-label fw-medium">16. Manager Name (Optional)</label>
                            <input type="text" class="form-control" id="inf_managerName" name="managerName" placeholder="e.g. Sohail">
                        </div>
                        <div class="col-md-6">
                            <label for="inf_managerNumber" class="form-label fw-medium">Manager Mobile Number (Optional)</label>
                            <input type="text" class="form-control" id="inf_managerNumber" name="managerNumber" placeholder="e.g. +91 98421 58724">
                        </div>
                    </div>

                    <!-- 4. Payment Details -->
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2"><i class="fa-solid fa-wallet me-2"></i>4. Financial & Payment Information</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="inf_paymentDetails" class="form-label fw-medium">7. Payment Details</label>
                            <textarea class="form-control" id="inf_paymentDetails" name="paymentDetails" rows="2" placeholder="e.g. UPI ID: irfan@paytm | Bank: HDFC Bank, A/C No: 501002341298, IFSC: HDFC0000123"></textarea>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4 py-2 shadow-sm">Save Profile</button>
                </div>
            </form>
        </div>
    </div>
</div>

