@model CampaignManagement.Models.DTOs.ApiResponseDTO
@{
    ViewData["Title"] = "Reports Summary";
}

<div class="mb-4">
    <h1 class="page-title mb-1">Reports Summary</h1>
    <p class="text-muted mb-0">Track and download reporting metrics and billing invoices.</p>
</div>

<div class="row">
    <div class="col-md-8 mb-4">
        <div class="custom-card h-100">
            <h5 class="fw-bold mb-4">Reports Status</h5>
            
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-file-pdf text-danger fs-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Q1 Performance Collaboration Report</h6>
                            <span class="text-muted fs-8">Generated on 15 Feb 2026</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3"><i class="fa-solid fa-download"></i> Download</button>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-file-pdf text-danger fs-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Monthly Cost-per-Download Analytics</h6>
                            <span class="text-muted fs-8">Generated on 28 Feb 2026</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3"><i class="fa-solid fa-download"></i> Download</button>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-file-pdf text-danger fs-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Influencer Campaign Engagement Invoices</h6>
                            <span class="text-muted fs-8">Generated on 02 Mar 2026</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3"><i class="fa-solid fa-download"></i> Download</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="custom-card h-100">
            <h5 class="fw-bold mb-4">Quick Stats</h5>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Total Downloaded Reports</span>
                    <span class="fw-bold text-dark">12</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Pending Audits</span>
                    <span class="fw-bold text-warning">2</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">System Logs Count</span>
                    <span class="fw-bold text-success">356</span>
                </li>
            </ul>
        </div>
    </div>
</div>
