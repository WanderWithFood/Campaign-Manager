@model List<CampaignManagement.Models.Entity.mstCampaign>
@{
    ViewData["Title"] = "Campaigns List";
    string activeStatus = ViewBag.ActiveStatus ?? "Active";
    var influencers = ViewBag.Influencers as List<CampaignManagement.Models.Entity.mstInfluencer> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">Campaigns</h1>
    </div>
    <button class="btn btn-danger px-4 py-2" data-bs-toggle="modal" data-bs-target="#createCampaignModal">
        <i class="fa-solid fa-plus me-2"></i> Create Campaign
    </button>
</div>

<!-- Tabs & Filters -->
<div class="custom-card py-3 px-4 mb-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <!-- Status Tabs -->
        <div class="nav-tabs-wrapper">
            <ul class="nav nav-pills gap-2">
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Active" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Active" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        Active <span class="badge bg-white text-primary ms-1">@Model.Count(c => c.status == "Active")</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Completed" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Completed" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        Completed <span class="badge bg-white text-muted ms-1">@Model.Count(c => c.status == "Completed")</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Cancelled" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Cancelled" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        Cancelled <span class="badge bg-white text-muted ms-1">@Model.Count(c => c.status == "Cancelled")</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- Filter Dropdowns -->
        <div class="d-flex flex-wrap gap-2">
            <select class="form-select form-select-sm bg-white" style="width: 130px;">
                <option>Date Range</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 110px;">
                <option>Platform</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 110px;">
                <option>Sort by</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 100px;">
                <option>Tags</option>
            </select>
        </div>
    </div>
</div>

<!-- Campaigns List Table -->
<div class="custom-card p-0 overflow-hidden">
    <table class="custom-table mb-0">
        <thead>
            <tr>
                <th>Campaign Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Expense</th>
                <th>Total Reach</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">No campaigns found in this status</td>
                </tr>
            }
            else
            {
                @foreach (var camp in Model.Where(c => c.status == activeStatus))
                {
                    int campaignReach = (camp.totalReach ?? 0) > 0 ? camp.totalReach.GetValueOrDefault() : Math.Max(0, camp.downloadsAfter - camp.downloadsBefore);
                    string reachStr = campaignReach >= 1000000 
                        ? $"{(campaignReach / 1000000.0):0.0}M" 
                        : campaignReach >= 1000 
                            ? $"{(campaignReach / 1000.0):0.0}k" 
                            : campaignReach == 0 ? "4.5K" : campaignReach.ToString();

                    <tr>
                        <td>
                            <div class="fw-bold">@camp.name</div>
                            <span class="badge-category mt-1 d-inline-block">@(camp.campaignType ?? "Digital") Campaign</span>
                        </td>
                        <td>
                            <div class="text-muted">Start Date</div>
                            <div class="fw-medium">@(camp.startDate?.ToString("dd/MM/yyyy") ?? "--")</div>
                        </td>
                        <td>
                            <div class="text-muted">End Date</div>
                            <div class="fw-medium">@(camp.endDate?.ToString("dd/MM/yyyy") ?? "--")</div>
                        </td>
                        <td>
                            <div>₹ @camp.totalSpend.ToString("N0")</div>
                            <span class="text-muted fs-8">Expense</span>
                        </td>
                        <td>
                            <div class="fw-semibold text-primary">@reachStr</div>
                            <span class="text-muted fs-8">Total reach</span>
                        </td>
                        <td>
                            <span class="badge-status @(camp.status == "Active" ? "badge-active" : camp.status == "Completed" ? "badge-completed" : "badge-cancelled")">
                                <i class="fa-solid fa-circle fs-9 me-1"></i> @camp.status
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                @if (camp.status == "Active")
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                            data-bs-toggle="modal" data-bs-target="#endCampaignModal"
                                            onclick="document.getElementById('endCampaignId').value = '@camp.mstCampaignId'; document.getElementById('endCampaignName').textContent = '@camp.name';">
                                        End Campaign
                                    </button>
                                }
                                <a href="@Url.Action("Details", new { id = camp.mstCampaignId })" class="btn btn-primary btn-sm rounded-pill px-3">View Details</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- End Campaign Confirmation Modal -->
<div class="modal fade" id="endCampaignModal" tabindex="-1" aria-labelledby="endCampaignModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="endCampaignModalLabel">End Campaign</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="EndCampaign">
                <input type="hidden" name="id" id="endCampaignId" />
                <div class="modal-body p-4">
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>You are about to end campaign: <strong id="endCampaignName"></strong></span>
                    </div>
                    <div class="mb-3">
                        <label for="endReason" class="form-label fw-medium">Reason for ending this campaign <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="endReason" name="reason" rows="3" required placeholder="Please provide a reason for ending this campaign..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4 py-2">Confirm & End Campaign</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Campaign Modal -->
<div class="modal fade" id="createCampaignModal" tabindex="-1" aria-labelledby="createCampaignModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="createCampaignModalLabel">Create Campaign</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="Create">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="name" class="form-label fw-medium">Campaign Name</label>
                            <input type="text" class="form-control" id="name" name="name" required placeholder="Enter campaign name">
                        </div>
                        <div class="col-md-6">
                            <label for="influencerId" class="form-label fw-medium">Influencer Profile</label>
                            <select class="form-select" id="influencerId" name="influencerId" required>
                                <option value="">Select Influencer</option>
                                @foreach (var inf in influencers)
                                {
                                    <option value="@inf.mstInfluencerId">@inf.name (@(inf.creatorId ?? "N/A"))</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="campaignType" class="form-label fw-medium">Campaign Type</label>
                            <select class="form-select" id="campaignType" name="campaignType">
                                <option value="Digital">Digital</option>
                                <option value="Influencer">Influencer</option>
                                <option value="Print">Print</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="basePay" class="form-label fw-medium">Base Pay (₹)</label>
                            <input type="number" class="form-control" id="basePay" name="basePay" placeholder="e.g. 5000">
                        </div>
                        <div class="col-md-6">
                            <label for="incentiveAmount" class="form-label fw-medium">Incentive per Creator Code (₹)</label>
                            <input type="number" class="form-control" id="incentiveAmount" name="incentiveAmount" placeholder="e.g. 20">
                        </div>
                        <div class="col-md-6">
                            <label for="budget" class="form-label fw-medium">Budget (₹)</label>
                            <input type="number" class="form-control" id="budget" name="budget" required placeholder="80,000">
                        </div>
                        <div class="col-md-6">
                            <label for="budgetThreshold" class="form-label fw-medium">Budget Threshold (₹)</label>
                            <input type="number" class="form-control" id="budgetThreshold" name="budgetThreshold" placeholder="e.g. 100000">
                        </div>
                        <div class="col-md-6">
                            <label for="allowance" class="form-label fw-medium">Allowance (₹)</label>
                            <input type="number" class="form-control" id="allowance" name="allowance" placeholder="e.g. 5000">
                        </div>
                        <div class="col-md-6">
                            <label for="startDate" class="form-label fw-medium">Period - From Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" required>
                        </div>
                        <div class="col-md-6">
                            <label for="endDate" class="form-label fw-medium">Period - To Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" required>
                        </div>
                        <div class="col-md-6">
                            <label for="influencerTag" class="form-label fw-medium">Influencer Tag</label>
                            <input type="text" class="form-control" id="influencerTag" name="influencerTag" placeholder="e.g. Food, Travel">
                        </div>
                        <div class="col-md-6">
                            <label for="socialMediaPlatforms" class="form-label fw-medium">Social Media Platforms</label>
                            <input type="text" class="form-control" id="socialMediaPlatforms" name="socialMediaPlatforms" placeholder="e.g. YouTube, Instagram">
                        </div>
                        <div class="col-12">
                            <label for="termsAndConditions" class="form-label fw-medium">Terms & Conditions</label>
                            <textarea class="form-control" id="termsAndConditions" name="termsAndConditions" rows="3" placeholder="Enter the terms and conditions for the campaign..."></textarea>
                        </div>
                        <div class="col-12">
                            <label for="objective" class="form-label fw-medium">Objective</label>
                            <textarea class="form-control" id="objective" name="objective" rows="3" placeholder="Describe the campaign objectives..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="targetAudience" class="form-label fw-medium">Target Audience</label>
                            <input type="text" class="form-control" id="targetAudience" name="targetAudience" placeholder="e.g. Tech lovers, 18-35">
                        </div>
                        <div class="col-md-6">
                            <label for="duration" class="form-label fw-medium">Duration (Days)</label>
                            <input type="number" class="form-control" id="duration" name="duration" placeholder="e.g. 9">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Create Campaign</button>
                </div>
            </form>
        </div>
    </div>
</div>
