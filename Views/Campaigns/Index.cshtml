@model List<CampaignManagement.Models.Entity.mstCampaign>
@{
    ViewData["Title"] = "Campaigns List";
    string activeStatus = ViewBag.ActiveStatus ?? "Active";
    var influencers = ViewBag.Influencers as List<CampaignManagement.Models.Entity.mstInfluencer> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">Campaigns</h1>
        <p class="text-muted mb-0">Create new campaigns or view existing and completed campaigns</p>
    </div>
    <button class="btn btn-danger px-4 py-2" data-bs-toggle="modal" data-bs-target="#createCampaignModal">
        <i class="fa-solid fa-plus me-2"></i> Create Campaign
    </button>
</div>

<!-- Tabs & Filters -->
<div class="custom-card py-3 px-4 mb-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <!-- Status Tabs -->
        <div class="nav-tabs-wrapper">
            <ul class="nav nav-pills gap-2">
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Active" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Active" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        <i class="fa-solid fa-play me-1 fs-8"></i> Active <span class="badge bg-white text-primary ms-1">@Model.Count(c => c.status == "Active")</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Completed" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Completed" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        <i class="fa-solid fa-check-circle me-1 fs-8"></i> Completed List <span class="badge bg-white text-muted ms-1">@Model.Count(c => c.status == "Completed")</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", new { status = "Cancelled" })" class="nav-link px-3 py-2 rounded-3 @(activeStatus == "Cancelled" ? "active btn-primary text-white" : "bg-light-gray text-muted")">
                        <i class="fa-solid fa-ban me-1 fs-8"></i> Cancelled <span class="badge bg-white text-muted ms-1">@Model.Count(c => c.status == "Cancelled")</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- Filter Dropdowns -->
        <div class="d-flex flex-wrap gap-2">
            <select class="form-select form-select-sm bg-white" style="width: 130px;">
                <option>Date Range</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 110px;">
                <option>Platform</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 110px;">
                <option>Sort by</option>
            </select>
            <select class="form-select form-select-sm bg-white" style="width: 100px;">
                <option>Tags</option>
            </select>
        </div>
    </div>
</div>

<!-- Campaigns List Table -->
<div class="custom-card p-0 overflow-hidden">
    <table class="custom-table mb-0">
        <thead>
            <tr>
                <th>Campaign Name</th>
                <th>Influencer Profile</th>
                <th>Period (Start - End)</th>
                <th>Expense / Budget</th>
                <th>Total Reach</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any(c => c.status == activeStatus))
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="fa-solid fa-folder-open fs-2 mb-2 text-secondary d-block"></i>
                        No @activeStatus.ToLower() campaigns found
                    </td>
                </tr>
            }
            else
            {
                @foreach (var camp in Model.Where(c => c.status == activeStatus))
                {
                    int campaignReach = (camp.totalReach ?? 0) > 0 ? camp.totalReach.GetValueOrDefault() : Math.Max(0, camp.downloadsAfter - camp.downloadsBefore);
                    string reachStr = campaignReach >= 1000000 
                        ? $"{(campaignReach / 1000000.0):0.0}M" 
                        : campaignReach >= 1000 
                            ? $"{(campaignReach / 1000.0):0.0}k" 
                            : campaignReach == 0 ? "4.5K" : campaignReach.ToString();

                    var linkedInfluencer = influencers.FirstOrDefault(i => i.mstInfluencerId == camp.influencerId);
                    string infName = linkedInfluencer?.name ?? camp.creatorName ?? "N/A";

                    <tr>
                        <td>
                            <div class="fw-bold">@camp.name</div>
                            <div class="d-flex align-items-center gap-1 mt-1">
                                <span class="badge-category">@(camp.campaignType ?? "Digital")</span>
                                @if (!string.IsNullOrEmpty(camp.influencerTag))
                                {
                                    <span class="badge bg-light text-muted border fs-9">#@camp.influencerTag</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">@infName</div>
                            <span class="text-muted fs-8">Influencer Profile</span>
                        </td>
                        <td>
                            <div class="fw-medium text-dark">@(camp.startDate?.ToString("dd/MM/yyyy") ?? "--") to @(camp.endDate?.ToString("dd/MM/yyyy") ?? "--")</div>
                            <span class="text-muted fs-8"><i class="fa-regular fa-calendar me-1"></i>Campaign Period</span>
                        </td>
                        <td>
                            <div class="fw-semibold">₹ @camp.totalSpend.ToString("N0")</div>
                            <span class="text-muted fs-8">Budget: ₹ @camp.budget.ToString("N0")</span>
                        </td>
                        <td>
                            <div class="fw-semibold text-primary">@reachStr</div>
                            <span class="text-muted fs-8">Total reach</span>
                        </td>
                        <td>
                            <span class="badge-status @(camp.status == "Active" ? "badge-active" : camp.status == "Completed" ? "badge-completed" : "badge-cancelled")">
                                <i class="fa-solid fa-circle fs-9 me-1"></i> @camp.status
                            </span>
                            @if (camp.status == "Completed" && !string.IsNullOrEmpty(camp.endReason))
                            {
                                <div class="text-muted fs-8 mt-1" title="Reason: @camp.endReason">
                                    <i class="fa-solid fa-info-circle me-1 text-info"></i> Reason provided
                                </div>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                @if (camp.status == "Active")
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                            data-bs-toggle="modal" data-bs-target="#endCampaignModal"
                                            onclick="document.getElementById('endCampaignId').value = '@camp.mstCampaignId'; document.getElementById('endCampaignName').textContent = '@camp.name';">
                                        End Campaign
                                    </button>
                                }
                                <a href="@Url.Action("Details", new { id = camp.mstCampaignId })" class="btn btn-primary btn-sm rounded-pill px-3">View Details</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- End Campaign Confirmation Modal -->
<div class="modal fade" id="endCampaignModal" tabindex="-1" aria-labelledby="endCampaignModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger" id="endCampaignModalLabel">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> End Campaign
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="EndCampaign">
                <input type="hidden" name="id" id="endCampaignId" />
                <div class="modal-body p-4">
                    <div class="alert alert-warning border-warning-subtle d-flex align-items-center gap-2 mb-3">
                        <div>
                            Ending this campaign will move it directly to the <strong>Completed list</strong>. Please provide a reason to continue.
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fs-8 text-muted mb-1">Target Campaign</label>
                        <div class="fw-bold text-dark fs-6" id="endCampaignName">--</div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label for="endReason" class="form-label fw-medium">Reason for ending campaign <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="endReason" name="reason" rows="3" required placeholder="Enter detailed reason for ending this campaign..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4 py-2">Confirm & Move to Completed List</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Campaign Modal -->
<div class="modal fade" id="createCampaignModal" tabindex="-1" aria-labelledby="createCampaignModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold" id="createCampaignModalLabel">Create New Campaign</h5>
                    <p class="text-muted fs-8 mb-0">Fill in campaign details, influencer profile link, period, and budget terms</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="Create">
                <div class="modal-body p-4">
                    <!-- Section 1: Basic Information -->
                    <div class="border-bottom pb-3 mb-3">
                        <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-bullhorn me-2"></i>Campaign & Influencer Profile</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="name" class="form-label fw-medium">Campaign Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="name" name="name" required placeholder="e.g. Summer Promo Launch">
                            </div>
                            <div class="col-md-6">
                                <label for="influencerId" class="form-label fw-medium">Influencer Profile <span class="text-danger">*</span></label>
                                <select class="form-select" id="influencerId" name="influencerId" required>
                                    <option value="">Select Influencer Profile (from Influencer Stat)</option>
                                    @foreach (var inf in influencers)
                                    {
                                        <option value="@inf.mstInfluencerId">@inf.name (@(inf.creatorId ?? "N/A")) - @(inf.category ?? "General")</option>
                                    }
                                </select>
                                <span class="text-muted fs-8">Select from influencers added on Influencer Stat page</span>
                            </div>
                            <div class="col-md-6">
                                <label for="campaignType" class="form-label fw-medium">Campaign Type <span class="text-danger">*</span></label>
                                <select class="form-select" id="campaignType" name="campaignType" required>
                                    <option value="Digital">Digital</option>
                                    <option value="Influencer">Influencer</option>
                                    <option value="Print">Print</option>
                                    <option value="Outdoor">Outdoor</option>
                                    <option value="Event">Event</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="influencerTag" class="form-label fw-medium">Influencer Tag</label>
                                <input type="text" class="form-control" id="influencerTag" name="influencerTag" placeholder="e.g. Food, Travel, Lifestyle">
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Period & Duration -->
                    <div class="border-bottom pb-3 mb-3">
                        <h6 class="fw-bold text-primary mb-3"><i class="fa-regular fa-calendar-days me-2"></i>Campaign Period</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label fw-medium">Period - From Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="startDate" name="startDate" required>
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label fw-medium">Period - To Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="endDate" name="endDate" required>
                            </div>
                        </div>
                    </div>

                    <!-- Section 3: Financials & Incentive -->
                    <div class="border-bottom pb-3 mb-3">
                        <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-indian-rupee-sign me-2"></i>Financials, Threshold & Incentive</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="basePay" class="form-label fw-medium">Base Pay (₹) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="basePay" name="basePay" required placeholder="e.g. 25000">
                            </div>
                            <div class="col-md-6">
                                <label for="incentiveAmount" class="form-label fw-medium">Incentive (₹ / Code Usage)</label>
                                <input type="number" class="form-control" id="incentiveAmount" name="incentiveAmount" placeholder="e.g. 20">
                            </div>
                            <div class="col-md-6">
                                <label for="budgetThreshold" class="form-label fw-medium">Budget Threshold (₹)</label>
                                <input type="number" class="form-control" id="budgetThreshold" name="budgetThreshold" placeholder="e.g. 100000">
                            </div>
                            <div class="col-md-6">
                                <label for="budget" class="form-label fw-medium">Total Allocated Budget (₹) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="budget" name="budget" required placeholder="e.g. 50000">
                            </div>
                        </div>
                    </div>

                    <!-- Section 4: Terms & Conditions & Objective -->
                    <div>
                        <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-file-contract me-2"></i>Terms, Conditions & Objective</h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="termsAndConditions" class="form-label fw-medium">Terms & Conditions</label>
                                <textarea class="form-control" id="termsAndConditions" name="termsAndConditions" rows="3" placeholder="Specify deliverables, payment schedule, exclusivity clauses..."></textarea>
                            </div>
                            <div class="col-12">
                                <label for="objective" class="form-label fw-medium">Campaign Objective</label>
                                <textarea class="form-control" id="objective" name="objective" rows="2" placeholder="Describe main goals (e.g. Drive 10,000 app installs)..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Create Campaign</button>
                </div>
            </form>
        </div>
    </div>
</div>

