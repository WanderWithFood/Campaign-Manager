@model CampaignManagement.Models.Entity.mstCampaign
@{
    ViewData["Title"] = Model.name;
    string activeTab = ViewBag.ActiveTab ?? "Overview";
    var expenses = ViewBag.Expenses as List<CampaignManagement.Models.Entity.trnExpense> ?? new();
    var deliverables = ViewBag.Deliverables as List<CampaignManagement.Models.Entity.trnDeliverable> ?? new();
    var stakeholders = ViewBag.Stakeholders as List<CampaignManagement.Models.Entity.mstStakeholder> ?? new();
    var linkedInfluencer = ViewBag.Influencer as CampaignManagement.Models.Entity.mstInfluencer;
    var influencers = ViewBag.Influencers as List<CampaignManagement.Models.Entity.mstInfluencer> ?? new();
    var partners = ViewBag.CampaignPartners as List<CampaignManagement.Models.Entity.mstInfluencer> ?? new();
    
    // Compute budget summary with 3 types
    decimal basePayAmount = Model.basePay;
    decimal incentiveTotal = Model.incentiveAmount * ((Model.totalReach ?? 0) > 0 ? Model.totalReach.GetValueOrDefault() : 100); // estimate if no reach yet
    decimal allowanceAmount = Model.allowance;
    decimal allocatedBudget = Model.budget;
    decimal totalSpent = Model.totalSpend;
    decimal remainingBudget = allocatedBudget - totalSpent;
    
    // Dynamic days remaining
    int daysRemaining = 0;
    if (Model.endDate.HasValue)
    {
        daysRemaining = Math.Max(0, (Model.endDate.Value - DateTime.Now).Days);
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
        <a href="@Url.Action("Index")" class="text-muted text-decoration-none">
            <i class="fa-solid fa-chevron-left me-1"></i> Campaign Details
        </a>
    </div>
    <div class="d-flex gap-2">
        @if (linkedInfluencer != null)
        {
            <a href="@Url.Action("Profile", "InfluencersStat", new { id = linkedInfluencer.mstInfluencerId })" class="btn btn-outline-success rounded-pill px-4">
                <i class="fa-solid fa-user me-2"></i> View Profile
            </a>
        }
        <button class="btn btn-outline-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#editCampaignModal">
            <i class="fa-solid fa-pen me-2"></i> Edit Campaign
        </button>
        @if (Model.status == "Active")
        {
            <button type="button" class="btn btn-danger rounded-pill px-4"
                    data-bs-toggle="modal" data-bs-target="#endCampaignDetailModal">
                End Campaign
            </button>
        }
    </div>
</div>

<!-- Tab bar -->
<div class="custom-card p-0 mb-4 overflow-hidden">
    <ul class="nav nav-tabs border-0 bg-light p-2 gap-2" id="campaignTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link border-0 rounded-3 px-4 py-2 @(activeTab == "Overview" ? "active bg-white fw-semibold text-primary shadow-sm" : "text-muted")" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab" aria-controls="overview" aria-selected="true">Overview</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link border-0 rounded-3 px-4 py-2 @(activeTab == "Budget" ? "active bg-white fw-semibold text-primary shadow-sm" : "text-muted")" id="budget-tab" data-bs-toggle="tab" data-bs-target="#budget" type="button" role="tab" aria-controls="budget" aria-selected="false">Budget</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link border-0 rounded-3 px-4 py-2 @(activeTab == "Partners" ? "active bg-white fw-semibold text-primary shadow-sm" : "text-muted")" id="partners-tab" data-bs-toggle="tab" data-bs-target="#partners" type="button" role="tab" aria-controls="partners" aria-selected="false">Partners and collaborator</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link border-0 rounded-3 px-4 py-2 @(activeTab == "StakeholdersInfo" ? "active bg-white fw-semibold text-primary shadow-sm" : "text-muted")" id="stakeholders-tab" data-bs-toggle="tab" data-bs-target="#stakeholders" type="button" role="tab" aria-controls="stakeholders" aria-selected="false">Stakeholders Info</button>
        </li>
    </ul>
</div>

<!-- Tab Contents -->
<div class="tab-content" id="campaignTabsContent">
    
    <!-- OVERVIEW TAB -->
    <div class="tab-pane fade @(activeTab == "Overview" ? "show active" : "")" id="overview" role="tabpanel" aria-labelledby="overview-tab">
        <div class="custom-card">
            <div class="d-flex align-items-center gap-2 mb-3">
                <h4 class="fw-bold mb-0">@Model.name</h4>
                <span class="badge bg-success-subtle text-success border border-success rounded-pill px-2 py-1 fs-8">@Model.status</span>
                <span class="badge bg-warning-subtle text-warning border border-warning rounded-pill px-2 py-1 fs-8">Recurring</span>
            </div>
            <div class="text-muted fs-7 mb-4">
                Campaign Type : <strong class="text-dark me-4">@Model.campaignType</strong>
                Campaign Cycle : <strong class="text-dark">@Model.campaignCycle</strong>
            </div>

            <!-- Stats Grid -->
            <h5 class="fw-bold mb-3">Campaign Stats</h5>
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Start Date</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-calendar-days text-danger me-2"></i>@(Model.startDate?.ToString("dd/MM/yyyy") ?? "--")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">End Date</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-calendar-days text-danger me-2"></i>@(Model.endDate?.ToString("dd/MM/yyyy") ?? "--")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Duration</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-hourglass-half text-danger me-2"></i>@(Model.duration ?? 9) Days</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Days Remaining</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-clock text-danger me-2"></i>@daysRemaining Days</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Total spend</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-indian-rupee-sign text-danger me-2"></i>₹ @Model.totalSpend.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Conversion rate</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-chart-line text-danger me-2"></i>@Model.conversionRate%</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Incentive per Code</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-coins text-danger me-2"></i>₹ @Model.incentiveAmount.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Incentive to be Paid</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-indian-rupee-sign text-success me-2"></i>₹ @incentiveTotal.ToString("N0")</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="p-3 border rounded bg-light">
                        <span class="text-muted fs-8 d-block mb-1">Total Reach</span>
                        <div class="fw-bold fs-6"><i class="fa-solid fa-eye text-danger me-2"></i>@((Model.totalReach ?? 0) > 0 ? Model.totalReach.GetValueOrDefault().ToString("N0") : "--")</div>
                    </div>
                </div>
            </div>

            <!-- Objective Panel -->
            <div class="mb-4">
                <h6 class="fw-bold">Objective</h6>
                <p class="text-muted bg-light p-3 border rounded">@(Model.objective ?? "No objective defined yet.")</p>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.termsAndConditions))
            {
                <div class="mb-4">
                    <h6 class="fw-bold">Terms & Conditions</h6>
                    <p class="text-muted bg-light p-3 border rounded" style="white-space: pre-line;">@Model.termsAndConditions</p>
                </div>
            }

            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold">Target Details</h6>
                    <ul class="list-group list-group-flush border rounded p-2 bg-light">
                        <li class="list-group-item bg-transparent d-flex justify-content-between">
                            <span class="text-muted">Target Audience</span>
                            <span class="fw-medium">@Model.targetAudience</span>
                        </li>
                        <li class="list-group-item bg-transparent d-flex justify-content-between">
                            <span class="text-muted">Budget</span>
                            <span class="fw-medium">₹ @Model.budget.ToString("N0")</span>
                        </li>
                        <li class="list-group-item bg-transparent d-flex justify-content-between">
                            <span class="text-muted">Creator Name</span>
                            <span class="fw-medium">@(linkedInfluencer?.name ?? Model.creatorName ?? "--")</span>
                        </li>
                        <li class="list-group-item bg-transparent d-flex justify-content-between">
                            <span class="text-muted">Influencer Tag</span>
                            <span class="fw-medium">@(Model.influencerTag ?? "--")</span>
                        </li>
                        <li class="list-group-item bg-transparent d-flex justify-content-between">
                            <span class="text-muted">Social Media Platforms</span>
                            <span>
                                <i class="fa-brands fa-youtube text-danger me-1"></i>
                                <i class="fa-brands fa-instagram text-danger"></i>
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- BUDGET TAB -->
    <div class="tab-pane fade @(activeTab == "Budget" ? "show active" : "")" id="budget" role="tabpanel" aria-labelledby="budget-tab">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Financial Stats</h5>
            <button class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
                <i class="fa-solid fa-plus me-1"></i> Add Expense
            </button>
        </div>

        <div class="row">
            <!-- Chart panel -->
            <div class="col-lg-6 mb-4">
                <div class="custom-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0">Budget vs Time Comparison</h6>
                        <span class="badge bg-danger-subtle text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Over Spending Risk</span>
                    </div>
                    <div style="height: 220px; width: 100%;">
                        <canvas id="budgetBarChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Budget summary card with 3 types -->
            <div class="col-lg-6 mb-4">
                <div class="custom-card h-100">
                    <h6 class="fw-bold mb-4">Budget Summary</h6>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between border-bottom pb-2">
                            <span class="text-muted">Allocated Budget</span>
                            <span class="fw-bold">₹ @allocatedBudget.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom pb-2">
                            <span class="text-muted">Total Spent</span>
                            <span class="fw-bold text-danger">₹ @totalSpent.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between pb-2">
                            <span class="text-muted">Remaining Budget</span>
                            <span class="fw-bold text-success">₹ @remainingBudget.ToString("N0")</span>
                        </div>
                    </div>
                    
                    <h6 class="fw-bold mt-4 mb-3 border-top pt-3">Budget Breakdown (3 Types)</h6>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                            <div>
                                <span class="fw-medium">1. Base Pay</span>
                                <span class="text-muted fs-8 d-block">Fixed fee paid to the influencer</span>
                            </div>
                            <span class="fw-bold">₹ @basePayAmount.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                            <div>
                                <span class="fw-medium">2. Incentive</span>
                                <span class="text-muted fs-8 d-block">₹ @Model.incentiveAmount.ToString("N0") per creator code usage</span>
                            </div>
                            <span class="fw-bold">₹ @incentiveTotal.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center pb-2">
                            <div>
                                <span class="fw-medium">3. Allowance</span>
                                <span class="text-muted fs-8 d-block">Food, transport & stakeholder compensation</span>
                            </div>
                            <span class="fw-bold">₹ @allowanceAmount.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Expenses List -->
        <div class="custom-card p-0 overflow-hidden">
            <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Expenses</h6>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle bg-white" type="button">
                        Sort by
                    </button>
                </div>
            </div>
            <table class="custom-table mb-0">
                <thead>
                    <tr>
                        <th>Expenses</th>
                        <th>Category</th>
                        <th>Paid To</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Proof</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!expenses.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No expenses recorded for this campaign</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var exp in expenses)
                        {
                            <tr>
                                <td class="fw-semibold">@exp.expenseName</td>
                                <td>@exp.category</td>
                                <td>@exp.paidTo</td>
                                <td class="fw-semibold text-danger">₹ @exp.amount.ToString("N0")</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill">@exp.status</span>
                                </td>
                                <td>@(exp.expenseDate?.ToString("dd MMM") ?? "--")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(exp.proofPath))
                                    {
                                        <a href="#" class="text-decoration-none"><i class="fa-solid fa-file-pdf text-danger me-1"></i> @exp.proofPath</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No proof</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- PARTNERS AND COLLABORATORS TAB -->
    <div class="tab-pane fade @(activeTab == "Partners" ? "show active" : "")" id="partners" role="tabpanel" aria-labelledby="partners-tab">
        <div class="row">
            <div class="col-md-5 mb-4">
                <div class="custom-card">
                    <h5 class="fw-bold mb-3">Collaborator Inventory</h5>
                    
                    <!-- Add Collaborator Form -->
                    <form method="post" asp-action="AddPartner" class="d-flex gap-2 mb-4">
                        <input type="hidden" name="campaignId" value="@Model.mstCampaignId" />
                        <select name="influencerId" class="form-select form-select-sm" required>
                            <option value="">Add Partner...</option>
                            @foreach (var inf in influencers.Where(i => i.mstInfluencerId != Model.influencerId && !partners.Any(p => p.mstInfluencerId == i.mstInfluencerId)))
                            {
                                <option value="@inf.mstInfluencerId">@inf.name</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">Link</button>
                    </form>

                    <h6 class="fw-bold mb-3">Campaign Influencers</h6>
                    @if (linkedInfluencer != null)
                    {
                        <div class="d-flex align-items-center justify-content-between border rounded p-3 bg-light mb-2">
                            <div class="d-flex align-items-center gap-3">
                                <div class="profile-avatar mb-0" style="width: 40px; height: 40px;">
                                    <img src="https://api.dicebear.com/7.x/pixel-art/svg?seed=@(linkedInfluencer.name)" alt="@linkedInfluencer.name" />
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1 fs-7">@linkedInfluencer.name <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-0 fs-9 ms-1">Primary</span></h6>
                                    <span class="text-muted fs-8">@(linkedInfluencer.niche ?? "Food, Travel")</span>
                                </div>
                            </div>
                            <a href="@Url.Action("Profile", "InfluencersStat", new { id = linkedInfluencer.mstInfluencerId })" class="btn btn-outline-primary btn-sm rounded-pill px-2 py-1 fs-8">Profile</a>
                        </div>
                    }

                    @foreach (var partner in partners)
                    {
                        <div class="d-flex align-items-center justify-content-between border rounded p-3 bg-light mb-2">
                            <div class="d-flex align-items-center gap-3">
                                <div class="profile-avatar mb-0" style="width: 40px; height: 40px;">
                                    <img src="https://api.dicebear.com/7.x/pixel-art/svg?seed=@(partner.name)" alt="@partner.name" />
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1 fs-7">@partner.name <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-0 fs-9 ms-1">Partner</span></h6>
                                    <span class="text-muted fs-8">@(partner.niche ?? "Food, Travel")</span>
                                </div>
                            </div>
                            <div class="d-inline-flex gap-2">
                                <a href="@Url.Action("Profile", "InfluencersStat", new { id = partner.mstInfluencerId })" class="btn btn-outline-primary btn-sm rounded-pill px-2 py-1 fs-8">Profile</a>
                                <form method="post" asp-action="RemovePartner" class="d-inline">
                                    <input type="hidden" name="campaignId" value="@Model.mstCampaignId" />
                                    <input type="hidden" name="influencerId" value="@partner.mstInfluencerId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-2 py-1 fs-8" onclick="return confirm('Remove collaborator?')"><i class="fa-regular fa-trash-can"></i></button>
                                </form>
                            </div>
                        </div>
                    }
                    
                    @if (linkedInfluencer == null && !partners.Any())
                    {
                        <div class="text-muted p-3 border rounded bg-light">No influencers linked to this campaign.</div>
                    }
                </div>
            </div>

            <!-- Agreement & Deliverables checklist -->
            <div id="detailedTermsSection" class="col-md-7 mb-4">
                <div class="custom-card">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h5 class="fw-bold mb-0">Agreement & Tracker</h5>
                        @if (linkedInfluencer != null)
                        {
                            <span class="badge bg-warning text-dark"><i class="fa-solid fa-star"></i> @linkedInfluencer.name</span>
                        }
                    </div>

                    @if (linkedInfluencer != null)
                    {
                        <div class="row mb-4">
                            <div class="col-6">
                                <span class="text-muted fs-8 d-block">Location</span>
                                <span class="fw-semibold">@(linkedInfluencer.location ?? "--")</span>
                            </div>
                            <div class="col-6">
                                <span class="text-muted fs-8 d-block">DOB</span>
                                <span class="fw-semibold">@(linkedInfluencer.dateOfBirth?.ToString("dd/MM/yyyy") ?? "--")</span>
                            </div>
                            <div class="col-6 mt-3">
                                <span class="text-muted fs-8 d-block">Gender</span>
                                <span class="fw-semibold">@(linkedInfluencer.gender ?? "--")</span>
                            </div>
                            <div class="col-6 mt-3">
                                <span class="text-muted fs-8 d-block">Creator ID</span>
                                <span class="fw-semibold">@(linkedInfluencer.creatorId ?? "--")</span>
                            </div>
                        </div>

                        <h6 class="fw-bold mb-3 border-bottom pb-2">Agreement Terms</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2 text-muted fs-7 mb-4">
                            @if (!string.IsNullOrEmpty(linkedInfluencer.integrationRequirements))
                            {
                                <li><i class="fa-solid fa-circle-check text-success me-2"></i><strong>Integration:</strong> @linkedInfluencer.integrationRequirements</li>
                            }
                            @if (!string.IsNullOrEmpty(linkedInfluencer.exclusivityClause))
                            {
                                <li><i class="fa-solid fa-circle-check text-success me-2"></i><strong>Exclusivity:</strong> @linkedInfluencer.exclusivityClause</li>
                            }
                            @if (!string.IsNullOrEmpty(linkedInfluencer.contentDurationClause))
                            {
                                <li><i class="fa-solid fa-circle-check text-success me-2"></i><strong>Content Duration:</strong> @linkedInfluencer.contentDurationClause</li>
                            }
                            @if (!string.IsNullOrEmpty(linkedInfluencer.paymentTerms))
                            {
                                <li><i class="fa-solid fa-circle-check text-success me-2"></i><strong>Payment Terms:</strong> @linkedInfluencer.paymentTerms</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted p-3 border rounded bg-light mb-4">No influencer linked — agreement terms unavailable.</div>
                    }

                    <h6 class="fw-bold mb-3">Deliverables and Objective Tracker</h6>
                    <table class="custom-table table-sm">
                        <thead>
                            <tr>
                                <th>Check Box</th>
                                <th>Deliverables</th>
                                <th>Completed on</th>
                                <th>Deadline</th>
                                <th>Evidence</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!deliverables.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">No deliverables tracked</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var del in deliverables)
                                {
                                    <tr>
                                        <td>
                                            <form method="post" asp-action="ToggleDeliverable" class="d-inline">
                                                <input type="hidden" name="id" value="@del.trnDeliverableId" />
                                                <input type="hidden" name="campaignId" value="@Model.mstCampaignId" />
                                                <input type="checkbox" name="isCompleted" value="true" @(del.isCompleted ? "checked" : "") onchange="this.form.submit()" class="form-check-input" />
                                            </form>
                                        </td>
                                        <td class="@(del.isCompleted ? "text-decoration-line-through text-muted" : "")">@del.deliverable</td>
                                        <td>@(del.completedOn?.ToString("dd Jan") ?? "--")</td>
                                        <td>@(del.deadline?.ToString("dd Jan") ?? "--")</td>
                                        <td>
                                            @if (del.evidence == "Link")
                                            {
                                                <a href="#" class="text-primary text-decoration-none">Link</a>
                                            }
                                            else if (del.evidence == "Attach" || del.evidence == "Screenshot.png")
                                            {
                                                <a href="#" class="text-muted text-decoration-none"><i class="fa-solid fa-paperclip"></i> @del.evidence</a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">--</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- STAKEHOLDERS TAB -->
    <div class="tab-pane fade @(activeTab == "StakeholdersInfo" ? "show active" : "")" id="stakeholders" role="tabpanel" aria-labelledby="stakeholders-tab">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Stakeholders Info</h5>
            <button class="btn btn-danger btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addStakeholderModal">
                <i class="fa-solid fa-plus me-1"></i> Add Profile
            </button>
        </div>

        <div class="custom-card p-0 overflow-hidden">
            <table class="custom-table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Company</th>
                        <th>Mobile</th>
                        <th>E-mail</th>
                        <th>Location</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!stakeholders.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No stakeholders registered for this campaign</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var stk in stakeholders)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@stk.name</td>
                                <td>@stk.role</td>
                                <td>@stk.company</td>
                                <td>@stk.mobile</td>
                                <td>@stk.email</td>
                                <td>@stk.location</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <form method="post" asp-action="DeleteStakeholder" asp-route-id="@stk.mstStakeholderId" asp-route-campaignId="@Model.mstCampaignId">
                                            <button type="submit" class="btn btn-link text-danger p-0" onclick="return confirm('Remove stakeholder?')">
                                                <i class="fa-regular fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- End Campaign Confirmation Modal (Details page) -->
<div class="modal fade" id="endCampaignDetailModal" tabindex="-1" aria-labelledby="endCampaignDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="endCampaignDetailModalLabel">End Campaign</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="EndCampaign" asp-route-id="@Model.mstCampaignId">
                <div class="modal-body p-4">
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>You are about to end campaign: <strong>@Model.name</strong></span>
                    </div>
                    <div class="mb-3">
                        <label for="detailEndReason" class="form-label fw-medium">Reason for ending this campaign <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="detailEndReason" name="reason" rows="3" required placeholder="Please provide a reason for ending this campaign..."></textarea>
