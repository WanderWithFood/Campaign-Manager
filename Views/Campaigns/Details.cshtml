@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Render Budget Bar Chart
            var budgetCanvas = document.getElementById('budgetBarChart');
            if (budgetCanvas) {
                const ctx = budgetCanvas.getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Time Elapsed', 'Budget Used'],
                        datasets: [{
                            data: [75, 95],
                            backgroundColor: ['#6366f1', '#22c55e'],
                            borderWidth: 0,
                            borderRadius: 8,
                            barThickness: 40
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                }
                            },
                            y: {
                                min: 0,
                                max: 100,
                                ticks: {
                                    callback: function(value) { return value + "%" }
                                },
                                grid: {
                                    color: '#e2e8f0'
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
