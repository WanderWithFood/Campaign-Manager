@model List<CampaignManagement.Models.Entity.mstUsers>
@{
    ViewData["Title"] = "User Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">Settings</h1>
    </div>
    <button class="btn btn-primary px-4 py-2" data-bs-toggle="modal" data-bs-target="#addUserModal">
        <i class="fa-solid fa-user-plus me-2"></i> Add User Profile
    </button>
</div>

<!-- Users List -->
<div class="custom-card p-0 overflow-hidden mb-4">
    <div class="p-3 bg-light border-bottom">
        <h5 class="fw-bold mb-0">System Users</h5>
    </div>
    <table class="custom-table mb-0">
        <thead>
            <tr>
                <th>User Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Gender</th>
                <th>DOB</th>
                <th>Access Level</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="fw-bold text-dark">@user.name</td>
                    <td>@user.email</td>
                    <td>@(user.phoneNumber ?? "--")</td>
                    <td>@(user.gender ?? "--")</td>
                    <td>@(user.dateOfBirth?.ToString("dd/MM/yyyy") ?? "--")</td>
                    <td>
                        <span class="badge bg-primary-subtle text-primary">
                            @(user.userAccessLevel == 3 ? "Super Admin" : user.userAccessLevel == 2 ? "Admin" : "User")
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1">Active</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="addUserModalLabel">Create User Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="Save">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="usr_name" class="form-label fw-medium">Full Name</label>
                        <input type="text" class="form-control" id="usr_name" name="name" required placeholder="e.g. Shiva Santhosh">
                    </div>
                    <div class="mb-3">
                        <label for="usr_email" class="form-label fw-medium">Email Address</label>
                        <input type="email" class="form-control" id="usr_email" name="email" required placeholder="name@domain.com">
                    </div>
                    <div class="mb-3">
                        <label for="usr_password" class="form-label fw-medium">Password</label>
                        <input type="password" class="form-control" id="usr_password" name="password" required placeholder="password">
                    </div>
                    <div class="mb-3">
                        <label for="usr_phone" class="form-label fw-medium">Phone Number</label>
                        <input type="text" class="form-control" id="usr_phone" name="phoneNumber" placeholder="e.g. 9842056897">
                    </div>
                    <div class="mb-3">
                        <label for="usr_gender" class="form-label fw-medium">Gender</label>
                        <select class="form-select" id="usr_gender" name="gender">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="usr_dob" class="form-label fw-medium">Date of Birth</label>
                        <input type="date" class="form-control" id="usr_dob" name="dateOfBirth">
                    </div>
                    <div class="mb-3">
                        <label for="usr_access" class="form-label fw-medium">User Access Level</label>
                        <select class="form-select" id="usr_access" name="userAccessLevel">
                            <option value="1">User</option>
                            <option value="2">Admin</option>
                            <option value="3">Super Admin</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>
