@model List<CampaignManagement.Models.Entity.mstCreatorCode>
@{
    ViewData["Title"] = "Creator Codes";
    var influencers = ViewBag.Influencers as List<CampaignManagement.Models.Entity.mstInfluencer> ?? new();
    var campaigns = ViewBag.Campaigns as List<CampaignManagement.Models.Entity.mstCampaign> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">Creator Codes</h1>
        <p class="text-muted mb-0">Manage promo codes and pay-per-install incentives for influencers</p>
    </div>
    <button class="btn btn-danger px-4 py-2" data-bs-toggle="modal" data-bs-target="#createCodeModal">
        <i class="fa-solid fa-plus me-2"></i> Generate Creator Code
    </button>
</div>

<!-- Stats Summary -->
<div class="kpi-grid mb-4">
    <div class="kpi-card">
        <div class="kpi-header">
            <span>Active Codes</span>
            <i class="fa-solid fa-qrcode text-success kpi-icon bg-light"></i>
        </div>
        <div class="kpi-value">@Model.Count(c => c.status == "Active")</div>
        <div class="kpi-subtext text-success">Tracking installations</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">
            <span>Total Usages</span>
            <i class="fa-solid fa-download text-primary kpi-icon bg-light"></i>
        </div>
        <div class="kpi-value">@Model.Sum(c => c.totalUsages).ToString("N0")</div>
        <div class="kpi-subtext text-success">App installs driven</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-header">
            <span>Incentives Due</span>
            <i class="fa-solid fa-indian-rupee-sign text-danger kpi-icon bg-light"></i>
        </div>
        <div class="kpi-value">₹ @Model.Sum(c => c.totalUsages * c.incentivePerUsage).ToString("N0")</div>
        <div class="kpi-subtext">Credit balance earned</div>
    </div>
</div>

<!-- Table List -->
<div class="custom-card p-0 overflow-hidden">
    <table class="custom-table mb-0">
        <thead>
            <tr>
                <th>Creator Code</th>
                <th>Influencer Profile</th>
                <th>Associated Campaign</th>
                <th>Usages</th>
                <th>Incentive / Usage</th>
                <th>Total Incentive</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-5">No creator codes generated yet</td>
                </tr>
            }
            else
            {
                @foreach (var code in Model)
                {
                    var influencerName = influencers.FirstOrDefault(i => i.mstInfluencerId == code.influencerId)?.name ?? "Unknown";
                    var campaign = campaigns.FirstOrDefault(c => c.mstCampaignId == code.campaignId);
                    var campaignName = campaign?.name ?? "Global (No Campaign)";
                    var totalEarned = code.totalUsages * code.incentivePerUsage;

                    <tr>
                        <td>
                            <span class="font-monospace fw-bold text-dark fs-6 bg-light px-2 py-1 border rounded">@code.code</span>
                            <div class="text-muted fs-8 mt-1">Generated: @(code.created_at?.ToString("dd/MM/yyyy") ?? "--")</div>
                        </td>
                        <td>
                            <div class="fw-bold">@influencerName</div>
                            <span class="text-muted fs-8">Id: @code.influencerId</span>
                        </td>
                        <td>
                            @if (campaign != null)
                            {
                                <a href="@Url.Action("Details", "Campaigns", new { id = code.campaignId })" class="fw-medium text-decoration-none">@campaignName</a>
                            }
                            else
                            {
                                <span class="text-muted">@campaignName</span>
                            }
                        </td>
                        <td>
                            <div class="fw-bold text-primary">@code.totalUsages.ToString("N0")</div>
                            <span class="text-muted fs-8">Downloads</span>
                        </td>
                        <td>₹ @code.incentivePerUsage.ToString("N2")</td>
                        <td>
                            <span class="fw-bold text-success fs-6">₹ @totalEarned.ToString("N0")</span>
                            <span class="text-muted fs-8 d-block">Due to Pay</span>
                        </td>
                        <td>
                            <span class="badge-status @(code.status == "Active" ? "badge-active" : "badge-cancelled")">
                                <i class="fa-solid fa-circle fs-9 me-1"></i> @code.status
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3"
                                        data-bs-toggle="modal" data-bs-target="#updateUsagesModal"
                                        onclick="document.getElementById('updateCodeId').value = '@code.mstCreatorCodeId'; document.getElementById('updateCodeText').textContent = '@code.code'; document.getElementById('updateCodeUsages').value = '@code.totalUsages';">
                                    Update Usages
                                </button>
                                <form method="post" asp-action="Delete" asp-route-id="@code.mstCreatorCodeId" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" onclick="return confirm('Retire this creator code?')">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Create Creator Code Modal -->
<div class="modal fade" id="createCodeModal" tabindex="-1" aria-labelledby="createCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="createCodeModalLabel">Generate Creator Code</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="Create">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="code" class="form-label fw-medium">Creator Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" id="code" name="code" required placeholder="e.g. IRFAN50" style="text-transform: uppercase;">
                        <span class="text-muted fs-8">Unique alphabetic code internally mapped to tracker link.</span>
                    </div>
                    <div class="mb-3">
                        <label for="influencerId" class="form-label fw-medium">Influencer Profile <span class="text-danger">*</span></label>
                        <select class="form-select" id="influencerId" name="influencerId" required>
                            <option value="">Select Influencer</option>
                            @foreach (var inf in influencers)
                            {
                                <option value="@inf.mstInfluencerId">@inf.name (@(inf.creatorId ?? "N/A"))</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="campaignId" class="form-label fw-medium">Associated Campaign</label>
                        <select class="form-select" id="campaignId" name="campaignId">
                            <option value="">No Campaign (Global Promotion)</option>
                            @foreach (var camp in campaigns)
                            {
                                <option value="@camp.mstCampaignId">@camp.name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="incentivePerUsage" class="form-label fw-medium">Incentive per Code usage (₹) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="incentivePerUsage" name="incentivePerUsage" required value="20" placeholder="e.g. 20">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Generate Code</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Usages Modal -->
<div class="modal fade" id="updateUsagesModal" tabindex="-1" aria-labelledby="updateUsagesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="updateUsagesModalLabel">Update Code Usages</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="UpdateUsages">
                <input type="hidden" name="id" id="updateCodeId" />
                <div class="modal-body p-4">
                    <div class="alert alert-info py-2">
                        <span>Updating usages for code: <strong class="font-monospace" id="updateCodeText"></strong></span>
                    </div>
                    <div class="mb-3">
                        <label for="updateCodeUsages" class="form-label fw-medium">Total Usages (App Installs)</label>
                        <input type="number" class="form-control" id="updateCodeUsages" name="totalUsages" required placeholder="Enter total code usages count">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
